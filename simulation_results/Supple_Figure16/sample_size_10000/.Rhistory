COL <- c("magenta1", "turquoise3", "#4fbf3c", "#8f9b4d","#1f4a00")
## the results of single variant and two variants
## put in supplementary
supple.index <- which(MSE.res$true_confounder == "single variant" | MSE.res$true_confounder == "two variants")
## results for main manuscript
MSE.res1 <- MSE.res[-supple.index, ]
## results for supplementary
MSE.res2 <- MSE.res[supple.index, ]
################################################
## Figure 5
## main manuscript
################################################
pdf("N_10000_six_populations.pdf", width = 18, height = 10)
ggplot(MSE.res, aes(x = conf, y = MSE, group = model_adjustment, color = model_adjustment)) +
geom_line() +
geom_point() +
geom_errorbar(aes(ymin = MSE - MSE_SE, ymax = MSE + MSE_SE), width = 0.5,
position = position_dodge(.001), size = 0.68) +
#scale_y_sqrt() +
scale_y_log10() +
facet_grid(true_prs ~ true_confounder, scales = "free") +
scale_color_manual(name = "model adjustment", values = COL) +
scale_x_discrete(labels = c(expression(paste(gamma, "=", "0.5")),
expression(paste(gamma, "=", "1.0")),
expression(paste(gamma, "=", "1.5")))) +
theme_bw() +
xlab("") +
ylab("MSE") +
theme(legend.position = "top") +
guides(color = guide_legend(override.aes = list(size = 3))) +
theme(panel.spacing = unit(0.1, "lines"),
panel.border = element_rect(color = "black", fill = NA, size = 0.66),
strip.background = element_rect(color = "black", size = 0.1),
#axis.ticks.x=element_blank(),
strip.text = element_text(size = 20),
axis.title.y = element_text(size = 25),
axis.text.x = element_text(size = 18),
axis.text.y = element_text(size = 20),
legend.text = element_text(size= 20),
legend.title = element_text(size = 20),
legend.key.width = unit(1.5,"cm"))
dev.off()
