## create a variable naming for 3 confounding effect size settings
MSE.res$conf <- factor(rep(c(1, 2, 3), each = 96))
## rename variables
## homogeneous/heterogeneous weighting PRS
MSE.res <- MSE.res %>% mutate(true_prs = recode(true_prs, "ancestry_homo" = "homogeneous PRS", "ancestry_hetero" = "heterogeneous PRS"))
## unknown genetic confounding
MSE.res <- MSE.res %>% mutate(true_confounder = recode(true_confounder,
"PRS_Conf" = "conf1 (local ancestry)",
"unobserved_PRS" = "conf2 (afr enriched)",
"unobserved_variant" = "single variant",
"unobserved_multivariant" = "two variants",
"PC" = "conf-pc*"))
## covariate to adjust
MSE.res <- MSE.res %>% mutate(model_adjustment = recode(model_adjustment,
"pc" = "conf-pc*",
"Data.PC2" = "PC2",
"Data.PC10" = "PC10",
"Data.PC20" = "PC20",
"grPRS" = "gePRS",
"lrPRS" = "lePRS",
"proportion_ancestry" = "gaProp"))
## change the display order in the figure
## without do this step
## the outputs of the figures are displayed by alphabetic orders (of the variables)
MSE.res$true_prs <- factor(MSE.res$true_prs, levels = c("homogeneous PRS","heterogeneous PRS"))
MSE.res$true_confounder <- factor(MSE.res$true_confounder, levels = c("conf1 (local ancestry)", "conf2 (afr enriched)", "single variant", "two variants", "conf-pc*", "none"))
MSE.res$model_adjustment <- factor(MSE.res$model_adjustment, levels = c("conf-pc*", "gaProp", "gePRS", "lePRS", "none", "PC2", "PC10", "PC20"))
#MSE.res$true_prs <- factor(MSE.res$true_prs, levels = c("homogeneous PRS","heterogeneous PRS"))
## compare ePRS and PCs
method_index <- which(MSE.res$model_adjustment %in% c("PC2", "PC10", "PC20", "gePRS", "lePRS"))
MSE.res <- MSE.res[method_index, ]
#COL <- c("magenta1", "turquoise3", "#f1d69b", "#c65a1c","#3e0a00")
COL <- c("magenta1", "#e07b7e", "turquoise3", "#38857d","#1b5950")
## the results of single variant and two variants
## put in supplementary
supple.index <- which(MSE.res$true_confounder == "single variant" | MSE.res$true_confounder == "two variants")
## results for main manuscript
MSE.res1 <- MSE.res[-supple.index, ]
## results for supplementary
MSE.res2 <- MSE.res[supple.index, ]
################################################
## Figure 5
## main manuscript
################################################
pdf("N_10000_six_populations.pdf", width = 18, height = 10)
ggplot(MSE.res, aes(x = conf, y = MSE, group = model_adjustment, color = model_adjustment)) +
geom_line() +
geom_point() +
geom_errorbar(aes(ymin = MSE - MSE_SE, ymax = MSE + MSE_SE), width = 0.5,
position = position_dodge(.001), size = 0.68) +
#scale_y_sqrt() +
scale_y_log10() +
facet_grid(true_prs ~ true_confounder, scales = "free") +
scale_color_manual(name = "model adjustment", values = COL) +
scale_x_discrete(labels = c(expression(paste(gamma, "=", "0.5")),
expression(paste(gamma, "=", "1.0")),
expression(paste(gamma, "=", "1.5")))) +
theme_bw() +
xlab("") +
ylab("MSE") +
theme(legend.position = "top") +
guides(color = guide_legend(override.aes = list(size = 3))) +
theme(panel.spacing = unit(0.1, "lines"),
panel.border = element_rect(color = "black", fill = NA, size = 0.66),
strip.background = element_rect(color = "black", size = 0.1),
#axis.ticks.x=element_blank(),
strip.text = element_text(size = 20),
axis.title.y = element_text(size = 25),
axis.text.x = element_text(size = 18),
axis.text.y = element_text(size = 20),
legend.text = element_text(size= 20),
legend.title = element_text(size = 20),
legend.key.width = unit(1.5,"cm"))
dev.off()
